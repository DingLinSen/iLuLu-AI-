{
  "name": "ai-chat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"cd server && node --watch index.js\"",
    "dev:client": "vite",
    "dev:server": "cd server && node --watch index.js",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "cd server && npm install",
    "start": "vite build && cd server && node index.js",
    "start:server": "cd server && node index.js"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "element-plus": "^2.14.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.4",
    "vue": "^3.5.35",
    "vue-element-plus-x": "^2.0.3",
    "x-markdown-vue": "^0.0.200"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.6.2",
    "concurrently": "^9.2.1",
    "vite": "^5.4.21"
  }
}
